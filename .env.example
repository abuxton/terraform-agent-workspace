# Terraform MCP Server .env (placeholders)
# Generated from https://github.com/hashicorp/terraform-mcp-server README.md
# Fill in values appropriate for your environment. Do NOT commit secrets in public repos.

# HCP Terraform / Terraform Enterprise address (default: https://app.terraform.io)
TFE_ADDRESS=https://app.terraform.io

# Terraform Enterprise API token (leave empty if not using TFE/HCP)
TFE_TOKEN=

# Skip TLS verification for TFE/HCP (true/false)
TFE_SKIP_TLS_VERIFY=false

# Transport mode: 'stdio' (default) or 'streamable-http' (or legacy 'http')
TRANSPORT_MODE=stdio

# Transport host and port (HTTP server binds to this when using streamable-http)
TRANSPORT_HOST=127.0.0.1
TRANSPORT_PORT=8080

# HTTP endpoint path for MCP (default: /mcp)
MCP_ENDPOINT=/mcp

# Session mode: 'stateful' (default) or 'stateless'
MCP_SESSION_MODE=stateful

# Comma-separated list of allowed origins for CORS (empty = none)
MCP_ALLOWED_ORIGINS=

# CORS mode: 'strict' (default), 'development', or 'disabled'
MCP_CORS_MODE=strict

# TLS certificate and key files (required for non-localhost deployments)
MCP_TLS_CERT_FILE=
MCP_TLS_KEY_FILE=

# Global and per-session rate limits (format: rps:burst). Defaults shown in README.
MCP_RATE_LIMIT_GLOBAL=10:20
MCP_RATE_LIMIT_SESSION=5:10

# Enable tools that require explicit approval (false by default)
ENABLE_TF_OPERATIONS=false

# Optional: logging path (server supports --log-file flag instead of env)
# LOG_FILE=/var/log/terraform-mcp-server.log

# Notes:
# - Do NOT commit this file containing real credentials. Keep secrets in your system's secret manager or a restricted .env stored outside the repo.
# - When using StreamableHTTP in non-local environments, set MCP_ALLOWED_ORIGINS to restrict origins and configure TLS using MCP_TLS_CERT_FILE and MCP_TLS_KEY_FILE.
