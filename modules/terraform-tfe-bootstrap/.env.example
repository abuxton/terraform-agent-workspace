# Example env file for modules/terraform-tfe-bootstrap
# Do NOT commit real tokens. Use a secure secrets manager or a local .env ignored by git.

# TFE / HCP host (default: https://app.terraform.io)
# Use Terraform CLI TF_VAR_<name> environment variables so Terraform automatically maps them to module variables.
TF_VAR_tfe_hostname=https://app.terraform.io

# Terraform Enterprise or HCP Terraform API token
TF_VAR_tfe_token=

# Skip TLS verification for enterprise installs with self-signed certs (true/false)
TF_VAR_tfe_ssl_skip_verify=false

# Optional: default organization name to use when creating resources
TF_VAR_tfe_organization=
